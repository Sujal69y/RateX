// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CompletionStatus {
  COMPLETED   @map("completed")
  IN_PROGRESS @map("in-progress")
  DROPPED     @map("dropped")
  PLANNING    @map("planning")
}

enum ReviewOutcome {
  GOT_INTERNSHIP @map("got-internship")
  GOT_JOB        @map("got-job")
  PROMOTION      @map("promotion")
  NO_IMPACT      @map("no-impact")
  STILL_LEARNING @map("still-learning")
  SIDE_PROJECT   @map("side-project")
  SKILL_UP       @map("skill-up")
}

enum SalaryImpact {
  NONE          @map("none")
  RANGE_0_10K   @map("0-10k")
  RANGE_10_30K  @map("10k-30k")
  RANGE_30_50K  @map("30k-50k")
  RANGE_50_PLUS @map("50k+")
}

model Course {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  provider        String
  description     String
  thumbnail       String?
  url             String
  price           Decimal?  @db.Decimal(10, 2)
  duration        Int?
  isFree          Boolean   @default(false)
  certificateType String?
  category        String
  subcategory     String?
  skills          String[]
  prerequisites   String[]
  lastUpdated     DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  reviews        Review[]
  projects       Project[]
  comparisonsA   Comparison[] @relation("ComparisonCourseA")
  comparisonsB   Comparison[] @relation("ComparisonCourseB")
  wonComparisons Comparison[] @relation("ComparisonWinner")

  @@index([provider])
  @@index([category])
  @@index([subcategory])
  @@index([isFree])
  @@index([isActive])
}

model Review {
  id               String           @id @default(cuid())
  userId           String
  courseId         String
  ratings          Json
  overallScore     Float
  reviewText       String?
  completionStatus CompletionStatus
  timeSpent        Int?
  outcome          ReviewOutcome
  salaryImpact     SalaryImpact
  wouldRecommend   Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId])
  @@index([overallScore])
  @@index([completionStatus])
  @@index([outcome])
}

model User {
  id              String   @id @default(cuid())
  name            String?
  email           String   @unique
  image           String?
  bio             String?
  currentRole     String?
  targetRole      String?
  skills          String[]
  isVerified      Boolean  @default(false)
  reputationScore Int      @default(0)
  createdAt       DateTime @default(now())

  reviews       Review[]
  projects      Project[]
  comparisons   Comparison[]
  learningPaths LearningPath[]

  @@index([reputationScore])
  @@index([isVerified])
}

model Project {
  id                 String   @id @default(cuid())
  userId             String
  courseId           String
  title              String
  description        String
  projectUrl         String?
  githubUrl          String?
  demoUrl            String?
  skillsDemonstrated String[]
  images             String[]
  createdAt          DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
}

model Comparison {
  id        String   @id @default(cuid())
  userId    String
  courseAId String
  courseBId String
  notes     String
  winnerId  String?
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseA Course  @relation("ComparisonCourseA", fields: [courseAId], references: [id], onDelete: Cascade)
  courseB Course  @relation("ComparisonCourseB", fields: [courseBId], references: [id], onDelete: Cascade)
  winner  Course? @relation("ComparisonWinner", fields: [winnerId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([courseAId])
  @@index([courseBId])
  @@index([winnerId])
}

model LearningPath {
  id          String   @id @default(cuid())
  title       String
  description String
  createdBy   String
  isOfficial  Boolean  @default(false)
  steps       Json[]
  tags        String[]
  upvotes     Int      @default(0)
  createdAt   DateTime @default(now())

  creator User @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([createdBy])
  @@index([isOfficial])
  @@index([upvotes])
}
